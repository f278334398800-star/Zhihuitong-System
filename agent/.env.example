# LLM配置
# 提供商: openai / anthropic / ollama（默认 openai）
LLM_PROVIDER=openai
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# RAG配置
VECTOR_STORE_PATH=./data/vector_store
CHUNK_SIZE=1500
CHUNK_OVERLAP=100
DOCSTORE_PATH=./data/docstore.db

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 系统提示词
SYSTEM_PROMPT=你是一个专业、友好、耐心的校园智慧通AI助手。你可以帮助师生解答校园相关问题，包括课程信息、成绩查询、校园生活等。你永远用简洁、清晰、礼貌的中文回答。

# 搜索工具配置（可选）
TAVILY_API_KEY=your_tavily_api_key
TAVILY_API_URL=https://api.tavily.com/v1/search

# Java后端配置
JAVA_BACKEND_URL=http://localhost:8080

# Embedding模型配置（默认使用 bge-large-zh-v1.5 中文模型）
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
# 推理设备：cpu / cuda / mps
EMBEDDING_DEVICE=cpu
